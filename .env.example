# Server
PORT=3000
NODE_ENV=production

# Database (MySQL/TiDB)
# الأفضل ضبط DATABASE_URL مباشرة. وإن كنت تستخدم خدمة MySQL في Railway
# فالتطبيق يقرأ تلقائياً MYSQL_URL أو المتغيرات المنفصلة
# (MYSQLHOST/MYSQLUSER/MYSQLPASSWORD/MYSQLDATABASE/MYSQLPORT) إن لم يكن DATABASE_URL مضبوطاً.
# مهم: بدون اتصال صحيح بقاعدة البيانات يعمل الموقع بنسخة مؤقتة وتُفقد البيانات عند إعادة التشغيل.
DATABASE_URL=mysql://user:password@host:port/database

# Authentication (JWT)
JWT_SECRET=your-jwt-secret-key-here

# OAuth
OAUTH_SERVER_URL=https://your-oauth-server.com
VITE_OAUTH_PORTAL_URL=https://your-oauth-portal.com
VITE_APP_ID=your-app-id

# Owner (auto-admin assignment)
OWNER_OPEN_ID=your-owner-open-id

# Storage (S3-compatible) - Optional
BUILT_IN_FORGE_API_URL=https://your-forge-api.com
BUILT_IN_FORGE_API_KEY=your-forge-api-key
